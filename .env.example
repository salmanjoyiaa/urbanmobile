# Supabase: set NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY (see your Supabase project settings).
# Storage: create the `maintenance-media` bucket (private) per supabase/migrations/00039_maintenance_marketplace.sql — required for maintenance request uploads and signed previews.

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Twilio Content Template SIDs (WhatsApp approved templates; optional – defaults used if unset)
# TWILIO_TEMPLATE_VISIT_CONFIRMATION_CUSTOMER_SID=HX68910b1b2d0a8ef427916ab56a70606a
# TWILIO_TEMPLATE_VISIT_ASSIGNED_PROPERTY_AGENT_SID=HX2a544304c912de7cd7aba8733a774e15
# TWILIO_TEMPLATE_VISIT_ASSIGNED_VISITING_AGENT_SID=HX6ff55189a698c948cfda4301dcd16764

# App (required for build)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
NEXT_PUBLIC_SITE_NAME=UrbanSaudi

# Admin WhatsApp – receives signup/visit notifications (optional)
ADMIN_WHATSAPP_NUMBER=+966500000000

# Resend email (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
